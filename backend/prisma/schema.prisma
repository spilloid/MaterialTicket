generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int          @id @default(autoincrement())
  // authProvider + subject identify an SSO identity. subject is the OIDC `sub`
  // or SAML nameID; null for local accounts. Unique per provider so the same
  // username can exist across providers without collision.
  authProvider      AuthProvider @default(local) @map("auth_provider")
  subject           String?      @db.VarChar(255)
  username          String       @unique @db.VarChar(100)
  // Argon2id hash; null for SSO-only accounts that never set a local password.
  passwordHash      String?      @map("password_hash") @db.VarChar(255)
  displayName       String?      @map("display_name") @db.VarChar(150)
  email             String?      @db.VarChar(255)
  role              UserRole     @default(technician)
  isActive          Boolean      @default(true) @map("is_active")
  // TOTP MFA (local accounts). totpSecret is the base32 seed; totpEnabled flips
  // true only after a code is verified. totpRecovery holds SHA-256 hashes of
  // one-time recovery codes (raw codes are shown once at enrollment).
  totpSecret        String?      @map("totp_secret") @db.VarChar(64)
  totpEnabled       Boolean      @default(false) @map("totp_enabled")
  totpRecovery      Json?        @map("totp_recovery")
  // Per-tech email signature (sanitized HTML), appended to outbound mail when the
  // composer's "include signature" toggle is on.
  signatureHtml     String?      @map("signature_html") @db.Text
  lastSeenAt        DateTime?    @map("last_seen_at")
  passwordChangedAt DateTime?    @map("password_changed_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  assignedTickets Ticket[]       @relation("AssignedTickets")
  authoredNotes   Note[]         @relation("AuthoredNotes")
  sessions        Session[]
  notifications   Notification[]
  mailIdentities  MailIdentity[]
  apiTokens       ApiToken[]

  @@unique([authProvider, subject])
  @@map("users")
}

// A long-lived personal access token, used by programmatic clients that can't do
// an interactive login or OIDC handshake (e.g. the MCP voice agent). The client
// sends the raw token as `Authorization: Bearer adk_…`; we store only its
// SHA-256 hash, exactly like Session, so the table is useless if read. The token
// authenticates AS its owning user — the user's role/RBAC apply and mutations are
// attributed to them (tagged with the auth channel) in the audit log. Revocable
// instantly (revokedAt) and independently of the user's password/sessions.
model ApiToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  name       String    @db.VarChar(150)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  // First chars of the raw token (e.g. "adk_1a2b3c"), shown in the UI so a user
  // can tell tokens apart without us ever storing the secret.
  prefix     String    @db.VarChar(20)
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_tokens")
}

// Server-side session. The browser cookie carries an opaque random token; we
// store only its SHA-256 hash, so a DB read never yields a usable session.
// Enables instant revocation (delete the row) which JWTs can't do.
model Session {
  id        String   @id @default(cuid())
  userId    Int      @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  userAgent String?  @map("user_agent") @db.VarChar(255)
  ip        String?  @db.VarChar(45)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// Single-row (id=1) effective auth configuration, editable from the Admin UI.
// Seeded from env vars on first boot; the DB row is authoritative afterward.
// Secrets are write-only over the API — never serialized back to the client.
model AuthSetting {
  id               Int      @id @default(1)
  localEnabled     Boolean  @default(true) @map("local_enabled")
  oidcEnabled      Boolean  @default(false) @map("oidc_enabled")
  oidcIssuerUrl    String?  @map("oidc_issuer_url") @db.VarChar(500)
  oidcClientId     String?  @map("oidc_client_id") @db.VarChar(255)
  oidcClientSecret String?  @map("oidc_client_secret") @db.VarChar(500)
  oidcRedirectUri  String?  @map("oidc_redirect_uri") @db.VarChar(500)
  samlEnabled      Boolean  @default(false) @map("saml_enabled")
  samlEntryPoint   String?  @map("saml_entry_point") @db.VarChar(500)
  samlIssuer       String?  @map("saml_issuer") @db.VarChar(255)
  samlIdpCert      String?  @map("saml_idp_cert") @db.Text
  // MFA policy. mfaRequired (default true) forces local accounts to enroll TOTP
  // before they can complete login. mfaIssuer is the label shown in authenticator apps.
  mfaRequired      Boolean  @default(true) @map("mfa_required")
  mfaIssuer        String?  @map("mfa_issuer") @db.VarChar(100)
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("auth_settings")
}

// Generic key/value settings store (jsonb), used for integration config that an
// admin edits in the UI: 'smtp', 'connectwise', 'tactical'. Seeded from env on
// first boot; the DB row wins afterward. Secret fields are write-only over the API.
model Setting {
  key       String   @id @db.VarChar(100)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// An IMAP mailbox polled for inbound email-to-ticket. Passwords are stored
// AES-256-GCM encrypted (ENCRYPTION_KEY) — never in plaintext, never serialized.
model Mailbox {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(150)
  host         String    @db.VarChar(255)
  port         Int       @default(993)
  secure       Boolean   @default(true)
  username     String    @db.VarChar(255)
  passwordEnc  String?   @map("password_enc") @db.Text
  folder       String    @default("INBOX") @db.VarChar(100)
  // Default company/board applied to tickets created from this mailbox.
  companyName  String?   @map("company_name") @db.VarChar(150)
  // A label auto-applied to tickets created from this mailbox (catchall vs
  // help@ vs a personal inbox land tagged differently). identityId is the default
  // send-from identity used when replying on a ticket that arrived here.
  labelId      Int?      @map("label_id")
  identityId   Int?      @map("identity_id")
  enabled      Boolean   @default(true)
  // Highest processed IMAP UID — dedupes so a message becomes at most one ticket/note.
  lastUid      Int?      @map("last_uid")
  lastPolledAt DateTime? @map("last_polled_at")
  lastError    String?   @map("last_error") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("mailboxes")
}

// A customer/organization. Tickets and devices carry a denormalized companyName
// string (for sync + back-compat) AND an optional companyId once linked here.
model Company {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(200)
  domain    String?  @db.VarChar(150)
  phone     String?  @db.VarChar(50)
  email     String?  @db.VarChar(255)
  website   String?  @db.VarChar(255)
  address   String?  @db.VarChar(500)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contacts Contact[]
  tickets  Ticket[]
  devices  Device[]
  probes   Probe[]

  @@map("companies")
}

// A person at a company (the "who" on a ticket).
model Contact {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  name      String   @db.VarChar(200)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  title     String?  @db.VarChar(150)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@index([companyId])
  @@map("contacts")
}

model Ticket {
  id               Int          @id @default(autoincrement())
  ticketNumber     String?      @map("ticket_number") @db.VarChar(50)
  title            String       @db.VarChar(255)
  summary          String?      @db.VarChar(500)
  description      String?      @db.Text
  status           String       @default("New") @db.VarChar(100)
  priority         String?      @db.VarChar(50)
  // companyName is kept denormalized (sync/back-compat); companyId links the
  // ticket to the Company record once associated.
  companyName      String?      @map("company_name") @db.VarChar(150)
  companyId        Int?         @map("company_id")
  contactId        Int?         @map("contact_id")
  assignee         String?      @db.VarChar(100)
  assigneeId       Int?         @map("assignee_id")
  source           TicketSource @default(local)
  // external_id holds the RFC 5322 Message-ID for imap-sourced tickets, which
  // can exceed 100 chars — keep at 255 so long Message-IDs don't overflow.
  externalId       String?      @map("external_id") @db.VarChar(255)
  externalProvider String?      @map("external_provider") @db.VarChar(50)
  // SLA tracking. The resolved policy (slaPolicyId) yields response/resolution
  // deadlines, recomputed when priority or company changes. firstRespondedAt is
  // stamped on the first outbound tech note/email and freezes the response clock.
  slaPolicyId      Int?         @map("sla_policy_id")
  responseDueAt    DateTime?    @map("response_due_at")
  resolutionDueAt  DateTime?    @map("resolution_due_at")
  firstRespondedAt DateTime?    @map("first_responded_at")
  closedAt         DateTime?    @map("closed_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  assigneeUser User?        @relation("AssignedTickets", fields: [assigneeId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  slaPolicy    SlaPolicy?   @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)
  notes        Note[]
  syncEntries  SyncLog[]
  deviceLinks  DeviceLink[]
  scriptJobs   ScriptJob[]
  attachments  Attachment[]
  notifications Notification[]
  labels       TicketLabel[]

  @@unique([externalId, externalProvider])
  @@index([companyId])
  @@index([responseDueAt])
  @@index([resolutionDueAt])
  @@map("tickets")
}

model Note {
  id         Int       @id @default(autoincrement())
  ticketId   Int       @map("ticket_id")
  content    String    @db.Text
  author     String    @db.VarChar(150)
  authorId   Int?      @map("author_id")
  noteType   NoteType  @default(note) @map("note_type")
  timeStart  DateTime? @map("time_start")
  timeStop   DateTime? @map("time_stop")
  // Canonical billable duration for time_entry notes (minutes). Lets users log
  // "30m" directly without start/stop; totals sum this field.
  minutes    Int?
  externalId String?   @map("external_id") @db.VarChar(255)
  // Email correspondence metadata (noteType = email). `content` holds the plain-text
  // body (search/preview); `htmlContent` holds the sanitized HTML rendered in the
  // conversation view. `direction` is "inbound" | "outbound". `inReplyTo` is the
  // Message-ID this email replied to, for thread rendering.
  direction   String?  @db.VarChar(10)
  htmlContent String?  @map("html_content") @db.Text
  emailFrom   String?  @map("email_from") @db.VarChar(320)
  emailTo     String?  @map("email_to") @db.Text
  emailCc     String?  @map("email_cc") @db.Text
  emailBcc    String?  @map("email_bcc") @db.Text
  subject     String?  @db.VarChar(255)
  inReplyTo   String?  @map("in_reply_to") @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorUser  User?        @relation("AuthoredNotes", fields: [authorId], references: [id])
  attachments Attachment[]

  @@map("notes")
}

// A file attached to a ticket (and optionally to a specific note, e.g. an email
// attachment). Bytes live in object storage (local disk or S3-compatible) keyed
// by storageKey; only metadata is in Postgres. storageBackend records which
// backend holds the bytes so downloads resolve correctly after a config change.
model Attachment {
  id             Int      @id @default(autoincrement())
  ticketId       Int      @map("ticket_id")
  noteId         Int?     @map("note_id")
  filename       String   @db.VarChar(500)
  contentType    String   @default("application/octet-stream") @map("content_type") @db.VarChar(150)
  size           Int      @default(0)
  storageBackend String   @default("local") @map("storage_backend") @db.VarChar(20)
  storageKey     String   @map("storage_key") @db.VarChar(500)
  createdBy      String?  @map("created_by") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  note   Note?  @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([noteId])
  @@map("attachments")
}

// A per-user notification, persisted so the bell badge survives reconnects and
// the WebSocket layer can replay unread items. Live delivery is best-effort over
// the socket; this table is the durable source of truth.
model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  type      String    @db.VarChar(50)
  ticketId  Int?      @map("ticket_id")
  title     String    @db.VarChar(255)
  body      String?   @db.Text
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// An SLA policy: response + resolution targets (minutes) that apply to tickets
// matched by priority and/or company. Resolution precedence when a ticket is
// scored: company+priority > company > priority > global default (both null).
model SlaPolicy {
  id               Int      @id @default(autoincrement())
  name             String   @db.VarChar(150)
  priority         String?  @db.VarChar(50)
  companyId        Int?     @map("company_id")
  responseMinutes  Int      @map("response_minutes")
  resolutionMinutes Int     @map("resolution_minutes")
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tickets Ticket[]

  @@index([companyId])
  @@map("sla_policies")
}

// A "send as" address for outbound ticket mail. Shared boxes (help@, support@)
// have userId = null; a personal alias is tied to a user. The chosen identity
// becomes the message From header; the SMTP envelope sender + auth stay the
// configured relay account so SPF/DKIM/DMARC are unaffected.
model MailIdentity {
  id          Int      @id @default(autoincrement())
  address     String   @unique @db.VarChar(320)
  displayName String?  @map("display_name") @db.VarChar(150)
  shared      Boolean  @default(true)
  userId      Int?     @map("user_id")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mail_identities")
}

// A reusable canned message / boilerplate for outbound mail. `bodyHtml` is
// sanitized HTML inserted into the composer; `subject` optionally prefills it.
model MailTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(150)
  subject   String?  @db.VarChar(255)
  bodyHtml  String   @map("body_html") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("mail_templates")
}

// A managed, colored label. Powers mailbox-based tagging today and ticket
// filtering generally. Applied to tickets through the TicketLabel join.
model Label {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  color     String   @default("#6750A4") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  tickets TicketLabel[]

  @@map("labels")
}

model TicketLabel {
  ticketId Int      @map("ticket_id")
  labelId  Int      @map("label_id")
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  label  Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([ticketId, labelId])
  @@index([labelId])
  @@map("ticket_labels")
}

// Polymorphic append-only log. entityType + entityId identify the target
// (ticket, note, device, probe, ...). No hard FK so any entity can be audited.
model AuditLog {
  id         BigInt      @id @default(autoincrement())
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   Int         @map("entity_id")
  action     AuditAction
  changedBy  String?     @map("changed_by") @db.VarChar(255)
  oldValue   Json?       @map("old_value")
  newValue   Json?       @map("new_value")
  occurredAt DateTime    @default(now()) @map("occurred_at")

  @@index([entityType, entityId], map: "idx_audit_entity")
  @@index([occurredAt], map: "idx_audit_time")
  @@map("audit_log")
}

model SyncProvider {
  id           Int          @id @default(autoincrement())
  name         String       @unique @db.VarChar(100)
  type         ProviderType
  config       Json
  enabled      Boolean      @default(true)
  lastSyncedAt DateTime?    @map("last_synced_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  syncLogs SyncLog[]

  @@map("sync_providers")
}

model SyncLog {
  id         BigInt        @id @default(autoincrement())
  providerId Int           @map("provider_id")
  externalId String?       @map("external_id") @db.VarChar(255)
  internalId Int?          @map("internal_id")
  direction  SyncDirection
  status     SyncStatus
  message    String?       @db.Text
  syncedAt   DateTime      @default(now()) @map("synced_at")

  provider SyncProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  ticket   Ticket?      @relation(fields: [internalId], references: [id])

  @@index([providerId, syncedAt], map: "idx_sync_provider")
  @@map("sync_log")
}

// A device record. Local-first: the source of truth lives here, just like
// tickets. RMM / scanner adapters (netviz, tactical_rmm) upsert into this table
// via DeviceProvider; standalone use needs no external system at all.
model Device {
  id               Int          @id @default(autoincrement())
  hostname         String?      @db.VarChar(255)
  displayName      String?      @map("display_name") @db.VarChar(255)
  ipAddress        String?      @map("ip_address") @db.VarChar(45)
  macAddress       String?      @map("mac_address") @db.VarChar(17)
  vendor           String?      @db.VarChar(150)
  os               String?      @db.VarChar(150)
  deviceType       String?      @map("device_type") @db.VarChar(100)
  openPorts        Json?        @map("open_ports")
  status           String       @default("unknown") @db.VarChar(50)
  companyName      String?      @map("company_name") @db.VarChar(150)
  companyId        Int?         @map("company_id")
  source           DeviceSource @default(local)
  probeId          Int?         @map("probe_id")
  externalId       String?      @map("external_id") @db.VarChar(255)
  externalProvider String?      @map("external_provider") @db.VarChar(50)
  metadata         Json?
  firstSeenAt      DateTime?    @map("first_seen_at")
  lastSeenAt       DateTime?    @map("last_seen_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  probe       Probe?       @relation(fields: [probeId], references: [id])
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ticketLinks DeviceLink[]
  scriptJobs  ScriptJob[]

  @@unique([externalId, externalProvider])
  @@index([companyName])
  @@map("devices")
}

// A script execution against a device through its RMM (the "act on machines"
// half of the thesis). Tracks run-now and scheduled invocations + their output.
model ScriptJob {
  id           Int             @id @default(autoincrement())
  deviceId     Int             @map("device_id")
  ticketId     Int?            @map("ticket_id")
  runner       String          @db.VarChar(50)
  scriptRef    String          @map("script_ref") @db.VarChar(150)
  scriptName   String?         @map("script_name") @db.VarChar(255)
  args         Json?
  status       ScriptJobStatus @default(queued)
  output       String?         @db.Text
  exitCode     Int?            @map("exit_code")
  scheduledFor DateTime?       @map("scheduled_for")
  createdBy    String?         @map("created_by") @db.VarChar(255)
  createdAt    DateTime        @default(now()) @map("created_at")
  startedAt    DateTime?       @map("started_at")
  completedAt  DateTime?       @map("completed_at")

  device Device  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([deviceId])
  @@index([status, scheduledFor])
  @@map("script_jobs")
}

// Many-to-many join: a ticket can reference multiple devices and vice versa.
model DeviceLink {
  id        Int      @id @default(autoincrement())
  ticketId  Int      @map("ticket_id")
  deviceId  Int      @map("device_id")
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([ticketId, deviceId])
  @@map("device_links")
}

// A deployed scanner/agent (e.g. a netviz instance on a customer LAN) that
// reports device records inbound. Authenticates with apiKey; heartbeats update
// status + lastSeenAt so the UI can show "probe online" on a ticket.
model Probe {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(150)
  apiKey      String      @unique @map("api_key") @db.VarChar(100)
  kind        String      @default("netviz") @db.VarChar(50)
  // companyName stays denormalized (back-compat / probe self-service); companyId
  // links the probe — and by extension its discovered devices — to a Company.
  companyName String?     @map("company_name") @db.VarChar(150)
  companyId   Int?        @map("company_id")
  cidr        String?     @db.VarChar(100)
  version     String?     @db.VarChar(50)
  status      ProbeStatus @default(offline)
  lastSeenAt  DateTime?   @map("last_seen_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  devices Device[]

  @@map("probes")
}

enum UserRole {
  admin
  technician
  readonly
}

enum AuthProvider {
  local
  oidc
  saml
}

enum TicketSource {
  local
  connectwise
  imap
  api
}

enum NoteType {
  note
  time_entry
  email
  // System/agent-generated internal note (e.g. an AVR phone-agent call summary
  // posted via the REST API). Renders like a standard internal note today.
  internal
}

enum AuditAction {
  create
  update
  delete
  sync
}

enum ProviderType {
  connectwise
  imap
  tactical_rmm
  meshcentral
  netviz
}

enum DeviceSource {
  local
  netviz
  tactical_rmm
  meshcentral
  api
}

enum ProbeStatus {
  online
  offline
  error
}

enum ScriptJobStatus {
  queued
  running
  success
  error
  canceled
}

enum SyncDirection {
  inbound
  outbound
}

enum SyncStatus {
  success
  error
  skipped
}
