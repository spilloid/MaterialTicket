# Server
SERVER_PORT=8060

# Database — PostgreSQL connection string for Prisma
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://stadmin:yourpassword@localhost:5432/anchordesk

# ─── Authentication ──────────────────────────────────────────────────────────
# AnchorDesk supports local accounts, OIDC SSO, and SAML side by side.
# Auth settings can ALSO be managed from the Admin UI; env vars below seed the
# initial config on first boot (the DB row wins once an admin edits it).

# APP_BASE_URL — public URL of the app, used to build OIDC/SAML callback URLs.
APP_BASE_URL=http://localhost:5173

# Public ticket numbers start at this width (supported range: 4–6).
TICKET_NUMBER_DIGITS=5

# AUTH_SESSION_SECRET — required in production. Signs session cookies.
# Generate one: `openssl rand -hex 32`
AUTH_SESSION_SECRET=

# Bootstrap admin — creates a local admin account on first boot IF no users
# exist yet. Safe to leave set; it is a no-op once any user is present.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@localhost

# SSO admin allowlist — comma-separated emails always granted the admin role on
# OIDC/SAML login (promotion-only; non-listed users are never demoted). Unlike
# BOOTSTRAP_ADMIN_*, this applies on every login, so it promotes an existing
# technician too. Leave blank to disable.
AUTH_ADMIN_EMAILS=

# Local accounts — set to 'false' to disable username/password login entirely
# (SSO-only deployments).
AUTH_LOCAL_ENABLED=true

# MFA (TOTP) — ON by default. Local accounts must enroll an authenticator app
# (scan a QR code) before they can finish logging in. Set MFA_REQUIRED=false to
# make it optional. SSO users get MFA from their IdP. MFA_ISSUER labels the
# entry shown in the authenticator app.
MFA_REQUIRED=true
MFA_ISSUER=AnchorDesk

# OIDC / SSO — works with Azure AD, Authentik, Okta, or any OIDC-compliant IdP.
# Leave OIDC_ISSUER_URL blank to disable OIDC.
#
# Azure AD example:
#   OIDC_ISSUER_URL=https://login.microsoftonline.com/<tenant-id>/v2.0
# Authentik example:
#   OIDC_ISSUER_URL=https://authentik.yourdomain.com/application/o/<app-slug>/
#
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Redirect/callback registered with the IdP. Defaults to APP_BASE_URL/api/auth/oidc/callback.
OIDC_REDIRECT_URI=

# SAML 2.0 — leave SAML_ENTRY_POINT blank to disable SAML.
# SAML_IDP_CERT is the IdP's base64 signing certificate (PEM body, no headers).
# ACS (callback) URL to register with the IdP: APP_BASE_URL/api/auth/saml/callback
SAML_ENTRY_POINT=
SAML_ISSUER=anchordesk
SAML_IDP_CERT=

# Set to 'true' to disable auth entirely in local dev (every request = dev admin).
OIDC_DISABLED=false

# SMTP relay (optional) — enables sending email from tickets.
# Point at an internal Postfix relay or any SMTP provider. Mail features stay
# disabled until SMTP_HOST is set.
SMTP_HOST=
SMTP_PORT=587
# true for implicit TLS (port 465); false for STARTTLS (587)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=anchordesk@localhost

# ─── Attachment storage (1.7.0) ──────────────────────────────────────────────
# Where ticket attachment bytes are stored. STORAGE_BACKEND=local writes to disk
# at STORAGE_LOCAL_DIR; STORAGE_BACKEND=s3 uses any S3-compatible store (AWS S3,
# MinIO, Cloudflare R2, Backblaze B2). These seed the `storage` config row on
# first boot and are editable in Admin → Integrations (DB wins afterward).
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./data/attachments
# S3 / S3-compatible (only used when STORAGE_BACKEND=s3). For non-AWS providers
# set S3_ENDPOINT and usually S3_FORCE_PATH_STYLE=true.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Tactical RMM (optional) — enables device sync + running scripts on devices.
# TRMM_API_URL is your Tactical API host (no trailing /api). Create the key in
# Tactical under Settings > Global Settings > API Keys.
TRMM_API_URL=https://api.spillerstech.us
TRMM_API_KEY=

# ConnectWise Manage (optional — only required if CW sync is enabled)
CWM_SERVER=your-instance.myconnectwise.net
CWM_COMPANY=your_company_name
CWM_PUBKEY=R5ykLVVHibpkr6zLKWX4agbF
CWM_PRIVATEKEY=your_private_key
CWM_CLIENTID=your_client_id
